# ============================================
# Tutora ENEM - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores reais
# NÃO cometa o arquivo .env com credenciais reais

# --------------------------------------------
# LLM Providers (Dex @dev & Aria @architect)
# --------------------------------------------
ANTHROPIC_API_KEY=        # Claude Sonnet 3.5/3.7 (Dex)
GOOGLE_GENERATIVE_AI_API_KEY= # Gemini Pro/Flash (Aria, Dara, Morgan, etc)
OPENAI_API_KEY=           # Opcional (se usar GPT-4o para alguma tarefa)

# --------------------------------------------
# Bot Telegram (Interface do Usuário)
# --------------------------------------------
TELEGRAM_BOT_TOKEN=       # @BotFather no Telegram
TELEGRAM_PARENT_CHAT_ID=  # ID do chat do pai para notificações/relatórios

# --------------------------------------------
# Supabase (Banco de Dados & Auth)
# --------------------------------------------
SUPABASE_URL=             # Dashboard > Settings > API
SUPABASE_ANON_KEY=        # Dashboard > Settings > API
SUPABASE_SERVICE_ROLE_KEY= # Dashboard > Settings > API (Uso interno/scripts)
# DATABASE_URL=           # (Opcional) URL direta para migrations complexas

# --------------------------------------------
# Automação n8n (Orquestração de Workflows)
# --------------------------------------------
N8N_BASE_URL=             # Ex: http://localhost:5678 ou https://n8n.seu-dominio.com
N8N_API_KEY=              # Settings > API

# --------------------------------------------
# NotebookLM & Processamento de Dados
# --------------------------------------------
# Estas são para os scripts python de ingestão
NOTEBOOKLM_EMAIL=         # Para autenticação via notebooklm-py
NOTEBOOKLM_PASSWORD=      # Para autenticação via notebooklm-py

# --------------------------------------------
# Outras Configurações
# --------------------------------------------
NODE_ENV=development
PROJECT_NAME=tutora-enem
DEBUG=true
